@page "{id}"
@model ViewModel

<article>
    <h1>Profile</h1>
    <ul>
        <li>Name: <span>@Html.DisplayFor(m => m.Data.Name)</span></li>
        <li>DoB: <span>@Html.DisplayFor(m => m.Data.DateOfBirth)</span></li>
        <li>Address: <span>@Html.DisplayFor(m => m.Data.Address)</span></li>
    </ul>
    <span>
        <a asp-page="Edit" asp-route-id="@Model.Data.Id">Edit</a>
    </span>
</article>